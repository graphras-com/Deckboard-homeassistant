# Environment variables for Deckboard Home Assistant
# Copy this to .env and fill in your values.
#
# Generate a long-lived access token in Home Assistant:
#   Profile -> Security -> Long-Lived Access Tokens -> Create Token

DECKBOARD_HA_TOKEN=your_long_lived_access_token_here

# Optional: override log level (DEBUG, INFO, WARNING, ERROR)
# DECKBOARD_LOG_LEVEL=INFO

# Optional: override config file path
# DECKBOARD_CONFIG=/home/pi/deckboard-homeassistant/deckboard.yaml
